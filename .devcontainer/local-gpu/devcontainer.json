  "dockerComposeFile": [
    "../../docker-compose.yml",
    "../../docker-compose.gpu.yml"
  ],
  "service": "app",
  "workspaceFolder": "/app",

  "overrideCommand": true,
  
  "customizations": {
    "vscode": {
